{
  "$id": "mesh/event.envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventEnvelope",
  "description": "Canonical envelope for persisted mesh events crossing systemd unit boundaries.",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "event_id",
    "ts",
    "topic",
    "source",
    "payload"
  ],
  "properties": {
    "schema_name": { "const": "event.envelope" },
    "schema_version": { "const": "v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string" },
    "run_id": { "type": "string" },
    "dedupe_key": { "type": "string" },
    "ts": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
