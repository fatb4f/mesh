#!/usr/bin/env python3
"""meshd daemon substrate."""

from __future__ import annotations

import argparse
from dataclasses import asdict, dataclass
import json
import os
import time
import tomllib
import uuid
from pathlib import Path
from typing import Any

try:
    from dataconfy import ConfigManager
except ImportError:  # pragma: no cover - optional dependency
    ConfigManager = None

try:
    from pydantic import BaseModel, Field, ValidationError
except ImportError:  # pragma: no cover - optional dependency
    BaseModel = None
    Field = None
    ValidationError = Exception

try:
    from xdg_base_dirs import xdg_cache_home, xdg_config_home, xdg_state_home
except ImportError:  # pragma: no cover - optional dependency
    xdg_cache_home = xdg_config_home = xdg_state_home = None


@dataclass
class MeshRuntimeData:
    router_log: str
    profile_log: str
    allowed_profiles: list[str]


@dataclass
class MeshConfigData:
    runtime: MeshRuntimeData


if BaseModel is not None:
    class MeshRuntimeModel(BaseModel):
        router_log: str
        profile_log: str
        allowed_profiles: list[str] = Field(default_factory=list)

    class MeshConfigModel(BaseModel):
        runtime: MeshRuntimeModel


def xdg_path(var: str, fallback: str) -> Path:
    if var == "XDG_CACHE_HOME" and xdg_cache_home is not None:
        return xdg_cache_home()
    if var == "XDG_CONFIG_HOME" and xdg_config_home is not None:
        return xdg_config_home()
    if var == "XDG_STATE_HOME" and xdg_state_home is not None:
        return xdg_state_home()
    return Path(os.environ.get(var, fallback)).expanduser()


def default_config_path() -> Path:
    return xdg_path("XDG_CONFIG_HOME", "~/.config") / "mesh" / "meshd.toml"


def default_values() -> dict[str, Any]:
    xdg_state = xdg_path("XDG_STATE_HOME", "~/.local/state")
    return {
        "runtime": {
            "router_log": str(xdg_state / "mesh" / "meshd-router.jsonl"),
            "profile_log": str(xdg_state / "mesh" / "meshd-profile.jsonl"),
            "allowed_profiles": [],
        }
    }


def load_config_via_dataconfy(path: Path) -> dict[str, Any] | None:
    if ConfigManager is None:
        return None
    if path.suffix.lower() not in {".yaml", ".yml", ".json"}:
        return None
    cfg = default_values()
    r = cfg["runtime"]
    defaults = MeshConfigData(
        runtime=MeshRuntimeData(
            router_log=str(r["router_log"]),
            profile_log=str(r["profile_log"]),
            allowed_profiles=[str(p) for p in r["allowed_profiles"]],
        )
    )
    mgr = ConfigManager(app_name="mesh", config_dir=path.parent, use_env_vars=True)
    loaded = mgr.load(MeshConfigData, filename=path.name)
    merged = defaults
    if loaded is not None:
        merged = loaded
    return asdict(merged)


def load_config(path: Path) -> dict[str, Any]:
    cfg = default_values()
    if not path.exists():
        loaded = {}
    elif path.suffix.lower() in {".yaml", ".yml", ".json"}:
        loaded = load_config_via_dataconfy(path) or {}
    else:
        loaded = tomllib.loads(path.read_text(encoding="utf-8"))
    if not isinstance(loaded, dict):
        loaded = {}
    section = loaded.get("runtime")
    if isinstance(section, dict):
        cfg["runtime"].update(section)
    if BaseModel is not None:
        try:
            validated = MeshConfigModel.model_validate(cfg)
            return validated.model_dump()
        except ValidationError as exc:
            raise SystemExit(f"invalid config: {exc}") from exc
    return cfg


def append_log(path: Path, row: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(row, sort_keys=True) + "\n")


def ensure_runtime_dirs() -> tuple[Path, Path, Path]:
    config_home = xdg_path("XDG_CONFIG_HOME", "~/.config") / "mesh"
    state_home = xdg_path("XDG_STATE_HOME", "~/.local/state") / "mesh"
    cache_home = xdg_path("XDG_CACHE_HOME", "~/.cache") / "mesh"
    config_home.mkdir(parents=True, exist_ok=True)
    state_home.mkdir(parents=True, exist_ok=True)
    cache_home.mkdir(parents=True, exist_ok=True)
    return config_home, state_home, cache_home


def base_row(action: str) -> dict[str, Any]:
    return {
        "event_id": str(uuid.uuid4()),
        "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "action": action,
    }


def cmd_daemon(args: argparse.Namespace) -> int:
    _, state_home, _ = ensure_runtime_dirs()
    cfg = load_config(Path(args.config).expanduser())
    router_log = Path(args.router_log or str(cfg["runtime"].get("router_log", state_home / "meshd-router.jsonl"))).expanduser()
    append_log(
        router_log,
        {
            **base_row("daemon_start"),
            "status": "scaffold",
            "message": "meshd daemon scaffold: router loop not implemented",
        },
    )
    return 0


def cmd_handle_event(args: argparse.Namespace) -> int:
    _, state_home, _ = ensure_runtime_dirs()
    cfg = load_config(Path(args.config).expanduser())
    router_log = Path(args.router_log or str(cfg["runtime"].get("router_log", state_home / "meshd-router.jsonl"))).expanduser()

    event_data = {}
    if args.stdin:
        raw = os.sys.stdin.read().strip()
        if raw:
            try:
                event_data = json.loads(raw)
            except json.JSONDecodeError:
                event_data = {"raw": raw, "invalid_json": True}
    elif args.event:
        try:
            event_data = json.loads(args.event)
        except json.JSONDecodeError:
            event_data = {"raw": args.event, "invalid_json": True}

    append_log(router_log, {**base_row("handle_event"), "event": event_data})
    return 0


def cmd_run_profile(args: argparse.Namespace) -> int:
    _, state_home, _ = ensure_runtime_dirs()
    cfg = load_config(Path(args.config).expanduser())
    profile_log = Path(args.profile_log or str(cfg["runtime"].get("profile_log", state_home / "meshd-profile.jsonl"))).expanduser()
    profile = (args.profile or "").strip()
    allowed = {str(p).strip() for p in cfg["runtime"].get("allowed_profiles", []) if str(p).strip()}
    allowed_ok = not allowed or profile in allowed

    append_log(
        profile_log,
        {
            **base_row("run_profile"),
            "profile": profile,
            "allowed": allowed_ok,
            "status": "scaffold",
        },
    )
    return 0 if allowed_ok else 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_daemon = sub.add_parser("daemon", help="Run mesh daemon loop")
    p_daemon.add_argument("--config", default=str(default_config_path()))
    p_daemon.add_argument("--router-log", default="")
    p_daemon.set_defaults(func=cmd_daemon)

    p_event = sub.add_parser("handle-event", help="Handle one JSON event")
    p_event.add_argument("--config", default=str(default_config_path()))
    p_event.add_argument("--event", required=False, default="")
    p_event.add_argument("--stdin", action="store_true")
    p_event.add_argument("--router-log", default="")
    p_event.set_defaults(func=cmd_handle_event)

    p_run = sub.add_parser("run-profile", help="Run named profile")
    p_run.add_argument("profile", nargs="?")
    p_run.add_argument("--config", default=str(default_config_path()))
    p_run.add_argument("--profile-log", default="")
    p_run.set_defaults(func=cmd_run_profile)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
